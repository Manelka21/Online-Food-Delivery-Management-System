<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  [L3] 📁 FILE: pom.xml
  🏗 LAYER: Build Configuration — Maven Project Object Model
  📋 ROLE: Defines the project structure, metadata, and external dependencies required for the Spring Boot application.
  🔗 USED BY: Maven build system and IDE (IntelliJ/Eclipse).
  ⚡ CONTEXT: Without this file, Java doesn't know how to download Spring or compile the server.
-->
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion> <!-- [L1] Specifies the version of the POM format -->

	<!-- 
	  [L2] Parent configuration inherited from Spring Boot. 
	  Provides "sensible defaults" for dependencies and plugin versions, significantly reducing boilerplate XML.
	-->
	<parent>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-starter-parent</artifactId>
		<version>3.2.4</version> <!-- [L1] Current stable version of Spring Boot -->
		<relativePath/> <!-- lookup parent from repository -->
	</parent>

	<groupId>com.fooddelivery</groupId> <!-- [L1] Unique identifier for the organization/project -->
	<artifactId>fdsys</artifactId> <!-- [L1] The name of the resulting JAR file -->
	<version>0.0.1-SNAPSHOT</version> <!-- [L1] Current project version (Snapshot means in-development) -->
	<name>fdsys</name> <!-- [L1] Human-readable project name -->
	<description>Food Delivery Management System - Member 1</description>

	<properties>
		<java.version>17</java.version> <!-- [L1] Forces the project to use Java 17 features -->
	</properties>

	<dependencies>
		<!-- 
		  [L2] The primary web dependency. 
		  Includes Tomcat (embedded server) and Spring MVC (for REST Controllers).
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-web</artifactId>
		</dependency>

		<!-- 
		  [L2] Developer Tools for faster iteration. 
		  Triggers a "Hot Reload" whenever a Java file is saved, saving development time.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-devtools</artifactId>
			<scope>runtime</scope>
			<optional>true</optional>
		</dependency>

		<!-- 
		  [L2] Spring Boot Test starter. 
		  Provides JUnit, Mockito, and AssertJ libraries for ensuring code quality.
		-->
		<dependency>
			<groupId>org.springframework.boot</groupId>
			<artifactId>spring-boot-starter-test</artifactId>
			<scope>test</scope>
		</dependency>
	</dependencies>

	<build>
		<plugins>
			<!-- 
			  [L2] The Spring Boot Maven Plugin. 
			  Bundles all dependencies into a single executable "Fat JAR" that can be run anywhere.
			-->
			<plugin>
				<groupId>org.springframework.boot</groupId>
				<artifactId>spring-boot-maven-plugin</artifactId>
				<configuration>
					<jvmArguments>--enable-native-access=ALL-UNNAMED</jvmArguments>
				</configuration>
			</plugin>
		</plugins>
	</build>
</project>
